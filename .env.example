# ===== NexusAgent Web 环境变量说明 =====
# 复制此文件为 .env，按需修改
# cp .env.example .env

# === 安全 ===
# Flask session 签名密钥（生产环境必须设置，否则每次重启会话失效）
# 生成命令: python3 -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=your-generated-secret-here

# === 多用户认证 (JWT) ===
# 必须设置，与 SECRET_KEY 不同
# 生成命令: python3 -c 'import secrets; print(secrets.token_hex(32))'
MULTI_USER_SECRET_KEY=your-jwt-secret-here

# JWT 过期时间（小时，默认 24）
# JWT_EXPIRY_HOURS=24

# === 生产模式 ===
# 设为 true 启用生产模式（禁用 debug，优化日志）
# Flask-SocketIO 会自动检测 eventlet 以支持 WebSocket
NEXUS_PRODUCTION=false

# === 服务器 ===
# 后端监听端口（默认 8765）
PORT=8765

# 前端开发服务器端口（仅开发模式，默认 5173）
FRONTEND_PORT=5173

# === CORS ===
# 仅当前后端分离部署时需要设置（格式: 逗号分隔的完整 URL）
# 同源部署（Flask 同时提供前端和 API）无需设置
# CORS_ORIGINS=http://your-frontend-domain.com,https://another-domain.com

# === Credits 计费 ===
# 统一 Credits 单价（每 1000 tokens 消耗的 Credits 数，默认 0.001）
# 计算公式: total_tokens / 1000 * UNIFORM_CREDITS_PER_1K
# UNIFORM_CREDITS_PER_1K=0.001

# === 健康检查 ===
# 后端启动超时秒数
HEALTH_CHECK_TIMEOUT=30

# === LLM API 密钥（根据需要设置）===
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
